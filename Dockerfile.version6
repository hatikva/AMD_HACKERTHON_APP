FROM python:3.12-slim AS version6-base

LABEL org.opencontainers.image.title="AMD Hackathon Track 1 Version 6 Runtime"
LABEL org.opencontainers.image.description="Batch-only CPU Ollama Nemotron runtime with environment-selected remote fallback."

RUN apt-get update \
    && apt-get install -y --no-install-recommends libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONUNBUFFERED=1
ENV APP_RUN_DIR=/output/audit
ENV MODEL_NAME=nemotron-3-nano:4b
ENV OLLAMA_MODEL_NAME=nemotron-3-nano:4b
ENV OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
ENV OLLAMA_HOST=127.0.0.1:11434
ENV OLLAMA_MODELS=/app/ollama-models
ENV OLLAMA_CONTEXT_LENGTH=128
ENV OLLAMA_MAX_LOADED_MODELS=1
ENV OLLAMA_NUM_PARALLEL=1
ENV OLLAMA_NO_CLOUD=true
ENV OLLAMA_FLASH_ATTENTION=false

WORKDIR /app

COPY pyproject.toml ./
COPY src ./src
COPY docs/VERSION6_SUBMISSION_RUNTIME.md ./docs/VERSION6_SUBMISSION_RUNTIME.md
COPY scripts/version6-entrypoint.sh /app/bin/version6-entrypoint.sh
COPY models/version5-ollama/bin/ollama /usr/local/bin/ollama
COPY models/version5-ollama/lib/ollama /usr/local/lib/ollama
COPY models/version5-ollama/models /app/ollama-models

RUN rm -rf src/amd_hackathon_app/__pycache__ \
    && rm -f src/amd_hackathon_app/analytics.py src/amd_hackathon_app/benchmarks.py src/amd_hackathon_app/ui.py \
    && python -m pip install --no-cache-dir . \
    && rm -rf build src/amd_hackathon_app.egg-info src/amd_hackathon_app/__pycache__ \
    && mkdir -p /input /output \
    && test -x /usr/local/bin/ollama \
    && test -x /app/bin/version6-entrypoint.sh \
    && test -s /app/ollama-models/blobs/sha256-527db2cf6c705d8fabb95693d038d9c06b4a2b0b8b0a4bbdbd01212d37242970 \
    && test ! -e /app/web \
    && test ! -e /app/benchmarks \
    && test ! -e /app/qualification \
    && test ! -e /app/build \
    && test ! -e /app/src/amd_hackathon_app/analytics.py \
    && test ! -e /app/src/amd_hackathon_app/benchmarks.py \
    && test ! -e /app/src/amd_hackathon_app/ui.py \
    && test ! -e /app/.env

ENTRYPOINT ["/app/bin/version6-entrypoint.sh"]

FROM version6-base AS version6-staging
ENV VERSION6_REMOTE_FALLBACK=staging
ENV STAGING_REMOTE_PROVIDER=ollama-cloud
ENV OLLAMA_CLOUD_BASE_URL=https://ollama.com
ENV VERSION6_SUBMISSION_STATUS=NOT_FOR_SUBMISSION
CMD ["amd-router", "run-submission", "--input", "/input/tasks.json", "--output", "/output/results.json", "--provider", "version6-staging"]

FROM version6-base AS version6-production
ENV VERSION6_REMOTE_FALLBACK=fireworks
CMD ["amd-router", "run-submission", "--input", "/input/tasks.json", "--output", "/output/results.json", "--provider", "version6-production"]
