FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=
FIREWORKS_MAX_RETRIES=4
FIREWORKS_RETRY_BACKOFF_SECONDS=2
FIREWORKS_TIMEOUT_SECONDS=300
OLLAMA_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com
STAGING_REMOTE_PROVIDER=ollama-cloud
STAGING_ALLOWED_MODELS=minimax-m3:cloud,nemotron-3-super:cloud,gpt-oss:20b-cloud,gemma4:31b-cloud
STAGING_INFERENCE_MODEL=
STAGING_MAX_RETRIES=2
STAGING_RETRY_BACKOFF_SECONDS=2
STAGING_TIMEOUT_SECONDS=180
ROUTING_PROFILE=version-3-work-jurisdiction
APP_RUN_DIR=runs
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
MODEL_NAME=qwen2.5-coder:3b
OLLAMA_MODEL_NAME=nemotron-3-nano:4b
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
