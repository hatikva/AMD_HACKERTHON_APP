FROM python:3.12-slim AS app

LABEL org.opencontainers.image.title="AMD Hackathon Track 1 Version 5 Ollama Experiment"
LABEL org.opencontainers.image.description="Experimental Ollama-backed local Nemotron runtime for size and memory comparison."

RUN apt-get update \
    && apt-get install -y --no-install-recommends libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONUNBUFFERED=1
ENV APP_RUN_DIR=/output/runs
ENV MODEL_NAME=nemotron-3-nano:4b
ENV OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
ENV OLLAMA_HOST=127.0.0.1:11434
ENV OLLAMA_MODELS=/app/ollama-models
ENV OLLAMA_CONTEXT_LENGTH=128
ENV OLLAMA_MAX_LOADED_MODELS=1
ENV OLLAMA_NUM_PARALLEL=1
ENV OLLAMA_NO_CLOUD=true
ENV OLLAMA_FLASH_ATTENTION=false

WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src
COPY docs ./docs
COPY scripts/version5-ollama-entrypoint.sh /app/bin/version5-ollama-entrypoint.sh
COPY models/version5-ollama/bin/ollama /usr/local/bin/ollama
COPY models/version5-ollama/lib/ollama /usr/local/lib/ollama
COPY models/version5-ollama/models /app/ollama-models

RUN python -m pip install --no-cache-dir . \
    && mkdir -p /input /output \
    && test -x /usr/local/bin/ollama \
    && test -x /app/bin/version5-ollama-entrypoint.sh \
    && test -s /app/ollama-models/blobs/sha256-527db2cf6c705d8fabb95693d038d9c06b4a2b0b8b0a4bbdbd01212d37242970

ENTRYPOINT ["/app/bin/version5-ollama-entrypoint.sh"]
CMD ["amd-router", "run-submission", "--input", "/input/tasks.json", "--output", "/output/results.json", "--provider", "ollama-demo"]
